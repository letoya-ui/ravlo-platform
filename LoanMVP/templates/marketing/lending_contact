{% extends "layouts/marketing_base.html" %}

{% block hero %}
<section class="mk-hero mk-hero-compact">
  <div class="mk-container">
    <div class="mk-hero-copy" style="max-width: 860px; margin: 0 auto; text-align: center;">
      <div class="mk-eyebrow">Ravlo Lending OS</div>
      <h1 class="mk-title-xl">Request a demo or start a lending conversation.</h1>
      <p class="mk-copy-lg">
        Tell us about your lending operation, team, and what you want to improve.
        We’ll guide the right next step.
      </p>
    </div>
  </div>
</section>
{% endblock %}

{% block content %}
<section class="mk-section">
  <div class="mk-container">

    <div class="mk-split-panel">

      <!-- LEFT SIDE -->
      <div class="mk-panel">
        <div class="mk-eyebrow">Connect With Ravlo</div>
        <h2 class="mk-title-lg">Built for lenders and operators.</h2>
        <p class="mk-copy-lg">
          Whether you want a demo, founders access, or licensing — start here.
        </p>

        <ul class="mk-bullet-list">
          <li>Live platform walkthrough</li>
          <li>Founders pricing access</li>
          <li>Licensing conversations</li>
          <li>Workflow + system review</li>
        </ul>

        <div class="mk-feature-card" style="margin-top: 24px;">
          <h3>Best fit</h3>
          <p>
            Private lenders, hard money lenders, DSCR lenders, mortgage teams,
            and growing lending operations.
          </p>
        </div>
      </div>

      <!-- RIGHT SIDE FORM -->
      <div class="mk-panel mk-panel-soft">

        <div class="mk-eyebrow">Request Form</div>
        <h3 style="margin-bottom: 10px;">Tell us about your team</h3>

        <form method="POST" action="{{ url_for('marketing.lenders_contact') }}" class="mk-form-grid">

          <!-- NAME + COMPANY -->
          <div class="mk-form-row">
            <div class="mk-form-group">
              <label>Full Name</label>
              <input type="text" name="name" placeholder="Your name" required>
            </div>

            <div class="mk-form-group">
              <label>Company Name</label>
              <input type="text" name="company_name" placeholder="Company name">
            </div>
          </div>

          <!-- EMAIL + PHONE -->
          <div class="mk-form-row">
            <div class="mk-form-group">
              <label>Email</label>
              <input type="email" name="email" placeholder="name@company.com" required>
            </div>

            <div class="mk-form-group">
              <label>Phone</label>
              <input type="text" name="phone" placeholder="(555) 555-5555">
            </div>
          </div>

          <!-- COMPANY TYPE + TEAM SIZE -->
          <div class="mk-form-row">
            <div class="mk-form-group">
              <label>Company Type</label>
              <select name="company_type">
                <option value="">Select</option>
                <option value="private_lender">Private Lender</option>
                <option value="hard_money">Hard Money Lender</option>
                <option value="mortgage">Mortgage Broker</option>
                <option value="dscr">DSCR Lender</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="mk-form-group">
              <label>Team Size</label>
              <select name="team_size">
                <option value="">Select</option>
                <option value="1-3">1–3</option>
                <option value="4-10">4–10</option>
                <option value="11-25">11–25</option>
                <option value="25+">25+</option>
              </select>
            </div>
          </div>

          <!-- INTEREST TYPE -->
          <div class="mk-form-group">
            <label>What are you interested in?</label>
            <select name="interest_type" required>
              <option value="">Select</option>
              <option value="demo" {% if selected_topic == 'demo' %}selected{% endif %}>Platform Demo</option>
              <option value="founders_access" {% if selected_topic == 'founders_access' %}selected{% endif %}>Founders Access</option>
              <option value="licensing" {% if selected_topic == 'licensing' %}selected{% endif %}>Licensing</option>
              <option value="white_label">White Label</option>
            </select>
          </div>

          <!-- CURRENT STACK -->
          <div class="mk-form-group">
            <label>Current Tools</label>
            <input type="text" name="current_stack" placeholder="CRM, LOS, spreadsheets, etc.">
          </div>

          <!-- MESSAGE -->
          <div class="mk-form-group">
            <label>What do you need help with?</label>
            <textarea name="message" rows="5" placeholder="Tell us your workflow or goals" required></textarea>
          </div>

          <!-- FOUNDERS CHECK -->
          <div class="mk-form-check">
            <input type="checkbox" name="founders_interest" value="yes">
            <label>Interested in founders pricing</label>
          </div>

          <!-- SUBMIT -->
          <div class="mk-form-actions">
            <button type="submit" class="mk-btn mk-btn-primary">
              Send Request
            </button>
          </div>

        </form>

      </div>

    </div>

  </div>
</section>

<!-- WHAT HAPPENS NEXT -->
<section class="mk-section mk-section-dark">
  <div class="mk-container">
    <div class="mk-section-head">
      <div class="mk-eyebrow">Next Step</div>
      <h2 class="mk-title-lg">What happens next</h2>
    </div>

    <div class="mk-feature-grid mk-feature-grid-3">

      <article class="mk-feature-card">
        <h3>1. Review</h3>
        <p>We review your lending setup and goals.</p>
      </article>

      <article class="mk-feature-card">
        <h3>2. Demo</h3>
        <p>We walk you through Ravlo Lending OS.</p>
      </article>

      <article class="mk-feature-card">
        <h3>3. Setup</h3>
        <p>If it’s a fit, we get your team onboarded.</p>
      </article>

    </div>
  </div>
</section>

{% endblock %}
