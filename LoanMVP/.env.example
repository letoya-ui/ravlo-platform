FLASK_ENV=development
FLASK_DEBUG=true

SECRET_KEY=replace-with-a-long-random-secret
SECURITY_PASSWORD_SALT=replace-with-a-long-random-salt
DATABASE_URL=sqlite:///local.db

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SOCKETIO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SOCKETIO_ASYNC_MODE=threading
CORS_SUPPORTS_CREDENTIALS=true

MAIL_SERVER=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@ravlohq.com
OPENAI_API_KEY=
AI_MODEL=gpt-4-turbo-preview

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

PROPERTY_PROVIDER=rentcast
RENTCAST_API_KEY=
RENTCAST_BASE_URL=https://api.rentcast.io/v1
RENTCAST_TIMEOUT=12
RENTCAST_COMP_COUNT=15
RENTCAST_MAX_RADIUS=2
RENTCAST_DAYS_OLD=180
RENTCAST_LOOKUP_SUBJECT_ATTRS=true
ENABLE_PROPERTY_CACHE=true

COMPANY_NAME=Ravlo
COMPANY_EMAIL=info@ravlohq.com
COMPANY_PHONE=
COMPANY_ADDRESS=

ENABLE_AI_CHAT=true
ENABLE_LOAN_ENGINE=true
ENABLE_CONSTRUCTION_MODE=false
ENABLE_DEVELOPER_TOOLS=true
BYPASS_PARTNER_SUBSCRIPTION=true
FREE_PARTNER_MODE=true
