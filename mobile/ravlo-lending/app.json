{
  "expo": {
    "name": "Ravlo Lending",
    "slug": "ravlo-lending",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": { "backgroundColor": "#0C1116" },
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.ravlo.lending" },
    "android": { "package": "com.ravlo.lending", "adaptiveIcon": { "backgroundColor": "#0C1116" } },
    "plugins": [
      "expo-secure-store",
      ["expo-notifications", { "color": "#3A5C7A" }],
      ["expo-image-picker", { "cameraPermission": "Ravlo needs camera access to photograph loan documents." }]
    ]
  }
}
