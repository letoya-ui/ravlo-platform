{
  "cli": {
    "version": ">= 13.0.0",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://ravlohq.com",
        "EXPO_NO_FINGERPRINT": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://ravlohq.com",
        "EXPO_NO_FINGERPRINT": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
