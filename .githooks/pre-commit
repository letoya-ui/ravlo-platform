#!/usr/bin/env bash
# Blocks commits that include .env files containing real secrets.
# .env.example files are allowed.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

blocked=()

while IFS= read -r file; do
  # Allow example/template files
  [[ "$file" == *.example ]] && continue
  [[ "$file" == *.sample ]]  && continue

  # Flag any .env file being added or modified
  if [[ "$file" =~ (^|/)\.env(\.|$) ]] || [[ "$file" =~ (^|/)\.env$ ]]; then
    blocked+=("$file")
  fi
done < <(git diff --cached --name-only --diff-filter=ACM)

if [[ ${#blocked[@]} -gt 0 ]]; then
  echo -e "${RED}[BLOCKED] Commit rejected — .env file(s) detected:${NC}"
  for f in "${blocked[@]}"; do
    echo -e "  ${YELLOW}$f${NC}"
  done
  echo ""
  echo "  .env files must never be committed. Add secrets to your"
  echo "  hosting provider's environment settings instead."
  echo "  If this is a template file, rename it to .env.example"
  echo ""
  exit 1
fi

exit 0
